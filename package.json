{
  "name": "@ilteoood/zorro",
  "version": "0.1.1",
  "type": "module",
  "description": "A powerful adapter that enables Zustand stores to connect to Redux DevTools remote server for debugging and state inspection.",
  "private": false,
  "scripts": {
    "build": "rozenite build",
    "dev": "redux-devtools --hostname=localhost --port=8000 & rozenite dev",
    "lint": "biome check",
    "lint:fix": "biome check --write"
  },
  "main": "./dist/react-native.cjs",
  "module": "./dist/react-native",
  "types": "./dist/react-native.d.ts",
  "exports": {
    ".": {
      "types": "./dist/react-native.d.ts",
      "import": "./dist/react-native.js",
      "require": "./dist/react-native.cjs"
    },
    "./metro": {
      "types": "./dist/metro.d.ts",
      "import": "./dist/metro.js",
      "require": "./dist/metro.cjs"
    }
  },
  "keywords": [
    "zustand",
    "redux-devtools",
    "remote",
    "react-native",
    "debugging",
    "state-management",
    "devtools"
  ],
  "author": "Matteo Pietro Dazzi",
  "license": "MIT",
  "dependencies": {
    "@rozenite/plugin-bridge": "1.7.0",
    "socketcluster-client": "^20.0.1",
    "zustand": ">=5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@redux-devtools/cli": "4.0.4",
    "@rozenite/vite-plugin": "1.7.0",
    "@types/css-modules": "^1.0.5",
    "@types/node": "^24.12.2",
    "@types/react": "~19.2.14",
    "@types/socketcluster-client": "^20.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.2",
    "react-native-web": "0.21.2",
    "rozenite": "1.7.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  },
  "peerDependencies": {
    "@redux-devtools/cli": "4.0.3",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "zustand": ">=5.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ilteoood/zorro.git"
  },
  "bugs": {
    "url": "https://github.com/ilteoood/zorro/issues"
  },
  "homepage": "https://github.com/ilteoood/zorro#readme"
}
